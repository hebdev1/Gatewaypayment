NEXT_PUBLIC_SUPABASE_URL=https://ohymckfsvkvvshexwuun.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx
SUPABASE_SERVICE_ROLE_KEY=legacy_service_role_if_needed
SUPABASE_FUNCTIONS_URL=https://ohymckfsvkvvshexwuun.functions.supabase.co
FUNCTIONS_URL=https://ohymckfsvkvvshexwuun.functions.supabase.co
PUBLIC_SITE_URL=http://localhost:3000
INTERNAL_FUNCTION_SECRET=replace_with_32_plus_random_chars
# Used by pg_cron → dispatch-webhooks. Generated automatically by the
# webhook_dispatcher_cron_job migration and stored in the Vault;
# mirror the same value as DISPATCHER_SECRET in Edge Function Secrets.
DISPATCHER_SECRET=replace_with_value_from_supabase_vault
# Used by pg_cron → send-emails. Same approach as DISPATCHER_SECRET.
EMAIL_SENDER_SECRET=replace_with_value_from_supabase_vault
CREDENTIAL_ENCRYPTION_KEY=base64_32_byte_key
# Resend (https://resend.com) — get a free API key (3k emails/month)
# and set both values in Supabase Edge Function Secrets.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxx
EMAIL_FROM=HaitiPay <noreply@yourdomain.com>
# Optional: per-API-key requests per minute (default 60)
API_RATE_LIMIT_PER_MINUTE=60
# Optional: comma-separated origin allow-list for edge function CORS
# CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
